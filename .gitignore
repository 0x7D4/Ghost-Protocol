# =============================================================================
# Ghost-Protocol .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# Rust build artifacts
# NOTE: Cargo.lock is intentionally NOT ignored — this is a binary project.
# -----------------------------------------------------------------------------
/target/
**/*.rs.bk

# -----------------------------------------------------------------------------
# eBPF compiled objects
# -----------------------------------------------------------------------------
**/*.o
**/*.elf
*.bpf.o

# -----------------------------------------------------------------------------
# WSL / cross-compilation artifacts
# -----------------------------------------------------------------------------
/target-bpf/

# -----------------------------------------------------------------------------
# Secrets — NEVER commit these
# -----------------------------------------------------------------------------
ghostd.toml
*.toml.local
.env
.env.*
secrets/
**/*secret*
**/*SECRET*

# -----------------------------------------------------------------------------
# OS files
# -----------------------------------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini

# -----------------------------------------------------------------------------
# Editor / IDE
# -----------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~
.direnv/
.envrc

# -----------------------------------------------------------------------------
# Test artifacts
# -----------------------------------------------------------------------------
/tmp/ghostd_test_*.sock
*.log
**/*.log

# -----------------------------------------------------------------------------
# Coverage and profiling
# -----------------------------------------------------------------------------
lcov.info
*.profraw
*.profdata
tarpaulin-report.html
